---
import type { CaseStudy } from '../data/caseStudies';

interface Props {
  study: CaseStudy;
}

const { study } = Astro.props;
const tagAttr = study.filterTags.join(',');
---
<a class="work-card" data-tags={tagAttr} href={study.href}>
  {study.preview.src ? (
    <div class="work-thumb" style="padding:0"><img src={study.preview.src} alt={study.preview.alt ?? ''} /></div>
  ) : (
    <div class="work-thumb">{study.preview.placeholder ?? ''}</div>
  )}
  <div class="work-body">
    <div class="work-client">{study.industry}</div>
    <div class="work-outcome">{study.subtitle}</div>
    <div class="work-meta">
      <span class="work-industry">{study.navTag}</span>
      <span class="work-arrow">→</span>
    </div>
  </div>
</a>
