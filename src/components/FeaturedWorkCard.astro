---
import type { CaseStudy } from '../data/caseStudies';

interface Props {
  study: CaseStudy;
}

const { study } = Astro.props;
---
<a class="fw-card" href={study.href}>
  {study.homeThumb ? (
    <div class="fw-thumb"><img src={study.homeThumb} alt="" /></div>
  ) : (
    <div class="fw-thumb fw-thumb-empty"></div>
  )}
  <div class="fw-title">{study.homeTitle}</div>
  <div class="fw-client">{study.client}</div>
  <div class="fw-outcome">{study.outcome}</div>
  <div class="fw-footer"><span class="fw-industry">{study.industry}</span><span class="fw-arrow">→</span></div>
</a>
