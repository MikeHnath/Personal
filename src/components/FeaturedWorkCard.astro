---
import type { CaseStudy } from '../data/caseStudies';

interface Props {
  study: CaseStudy;
}

const { study } = Astro.props;
---
<a class="fw-card" href={study.href}>
  {study.preview.src ? (
    <div class="fw-thumb"><img src={study.preview.src} alt={study.preview.alt ?? ''} /></div>
  ) : (
    <div class="fw-thumb fw-thumb-empty"></div>
  )}
  <div class="fw-client">{study.industry}</div>
  <div class="fw-outcome">{study.subtitle}</div>
  <div class="fw-footer"><span class="fw-industry">{study.navTag}</span><span class="fw-arrow">→</span></div>
</a>
