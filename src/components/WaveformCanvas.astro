---
interface Props {
  lines?: number;
  opacity?: number;
  speed?: number;
  amplitude?: number;
  class?: string;
}

const {
  lines = 12,
  opacity = 0.15,
  speed = 0.4,
  amplitude = 60,
  class: className = ''
} = Astro.props;
---

<canvas
  class={`waveform-canvas ${className}`.trim()}
  data-lines={lines}
  data-opacity={opacity}
  data-speed={speed}
  data-amplitude={amplitude}
  aria-hidden="true"
  style="color:var(--text)"
></canvas>

<style>
  .waveform-canvas{
    position:absolute;
    inset:0;
    width:100%;
    height:100%;
    pointer-events:none;
    display:block;
  }
</style>

<script>
  function parseColor(color: string): [number, number, number] {
    const m = color.match(/-?\d+(\.\d+)?/g);
    if (!m || m.length < 3) return [0, 0, 0];
    return [+m[0], +m[1], +m[2]];
  }

  function initWaveform(canvas: HTMLCanvasElement) {
    if (canvas.dataset.wfInited) return;
    canvas.dataset.wfInited = '1';

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const connectorCount = Math.max(4, +(canvas.dataset.lines || 12));
    const opacity = +(canvas.dataset.opacity || 0.15);
    const speed = +(canvas.dataset.speed || 0.4);
    const amplitude = +(canvas.dataset.amplitude || 60);

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = 0;
    let height = 0;
    let dpr = 1;

    const resize = () => {
      const rect = canvas.getBoundingClientRect();
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = Math.max(1, Math.round(rect.width));
      height = Math.max(1, Math.round(rect.height));
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.scale(dpr, dpr);
    };
    resize();

    let strokeRGB: [number, number, number] = [0, 0, 0];
    const refreshColor = () => {
      const c = getComputedStyle(canvas).color;
      const [r, g, b] = parseColor(c);
      // shift the color cooler — pull red back, push blue up
      strokeRGB = [
        Math.max(0, Math.min(255, r * 0.78)),
        Math.max(0, Math.min(255, g * 0.92)),
        Math.max(0, Math.min(255, b * 1.15 + 10))
      ];
    };
    refreshColor();

    const themeObs = new MutationObserver(refreshColor);
    themeObs.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme']
    });

    const ro = new ResizeObserver(() => resize());
    ro.observe(canvas);

    let raf = 0;
    let running = !reduce;
    const t0 = performance.now();

    const yWave = (
      x: number,
      ts: number,
      phase: number,
      sign: number
    ): number => {
      const cy = height / 2;
      const freq = 0.0038;
      return (
        cy +
        amplitude *
          0.85 *
          Math.sin(x * freq + ts * sign + phase) +
        amplitude *
          0.22 *
          Math.sin(x * freq * 2.3 + ts * sign * 1.4 + phase * 0.6 + 1.1)
      );
    };

    const drawFrame = (t: number) => {
      const ts = ((t - t0) / 1000) * speed;
      ctx.clearRect(0, 0, width, height);

      const step = Math.max(2, Math.floor(width / 240));
      const r = strokeRGB[0];
      const g = strokeRGB[1];
      const b = strokeRGB[2];
      const maxGap = amplitude * 2;

      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';

      // Stack of parallel waves between the two envelopes — each
      // intermediate line is a linear interpolation of yA and yB at
      // the same x, so they all run in parallel with the main
      // waves, and they collapse where the two cross (the ribbon's
      // edge fold).
      const totalLines = connectorCount + 2;

      // Pre-sample the three main envelopes once per frame.
      const sampleCount = Math.floor(width / step) + 1;
      const aSamples = new Float32Array(sampleCount);
      const cSamples = new Float32Array(sampleCount);
      const bSamples = new Float32Array(sampleCount);
      for (let s = 0; s < sampleCount; s++) {
        const x = s * step;
        aSamples[s] = yWave(x, ts, 0.0, 1);
        cSamples[s] = yWave(x, ts, Math.PI / 2, 1);
        bSamples[s] = yWave(x, ts, Math.PI, -1);
      }

      const half = 1 / 2;

      for (let i = 0; i < totalLines; i++) {
        const tI = totalLines === 1 ? 0.5 : i / (totalLines - 1);
        // distance to the nearest main line (positions 0, 1/2, 1)
        const distToMain = Math.min(
          Math.abs(tI - 0),
          Math.abs(tI - half),
          Math.abs(tI - 1)
        );
        // mains sit at base opacity; intermediates fade nearly to bg
        const a = opacity * Math.max(0.04, 1 - distToMain * 6);
        ctx.strokeStyle = `rgba(${r},${g},${b},${a})`;
        ctx.lineWidth = 0.7;
        ctx.beginPath();
        for (let s = 0; s < sampleCount; s++) {
          const x = s * step;
          let y: number;
          if (tI <= half) {
            const t2 = tI * 2;
            y = aSamples[s] * (1 - t2) + cSamples[s] * t2;
          } else {
            const t2 = (tI - half) * 2;
            y = cSamples[s] * (1 - t2) + bSamples[s] * t2;
          }
          if (s === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.stroke();
      }

      // Edge fade — trim alpha at left/right
      ctx.save();
      ctx.globalCompositeOperation = 'destination-in';
      const fadeWidth = Math.min(140, width * 0.18);
      const grad = ctx.createLinearGradient(0, 0, width, 0);
      grad.addColorStop(0, 'rgba(0,0,0,0)');
      grad.addColorStop(Math.min(0.499, fadeWidth / Math.max(width, 1)), 'rgba(0,0,0,1)');
      grad.addColorStop(Math.max(0.501, 1 - fadeWidth / Math.max(width, 1)), 'rgba(0,0,0,1)');
      grad.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, width, height);
      ctx.restore();

      if (running) raf = requestAnimationFrame(drawFrame);
    };

    if (running) {
      raf = requestAnimationFrame(drawFrame);
    } else {
      drawFrame(performance.now());
    }

    const onVisibility = () => {
      if (reduce) return;
      if (document.hidden) {
        running = false;
        cancelAnimationFrame(raf);
      } else if (!running) {
        running = true;
        raf = requestAnimationFrame(drawFrame);
      }
    };
    document.addEventListener('visibilitychange', onVisibility);
  }

  const boot = () => {
    document
      .querySelectorAll<HTMLCanvasElement>('canvas.waveform-canvas')
      .forEach(initWaveform);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
</script>
