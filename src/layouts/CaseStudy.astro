---
import Base from './Base.astro';
import CaseStudyNav from '../components/CaseStudyNav.astro';
import { getCaseStudy } from '../data/caseStudies';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const cs = getCaseStudy(slug);
if (!cs) throw new Error(`Unknown case study slug: ${slug}`);
---
<Base title={cs.pageTitle}>
  <div class="section">
    <a class="breadcrumb" href="/case-studies/">← <span>Case Studies</span> / {cs.breadcrumb}</a>
    {cs.hero.src ? (
      <div class="cs-hero" style="border:0;padding:0;overflow:hidden">
        <img src={cs.hero.src} alt={cs.hero.alt ?? ''} style="width:100%;height:100%;object-fit:cover;display:block" />
      </div>
    ) : (
      <div class="cs-hero">{cs.hero.placeholder}</div>
    )}
    <div class="cs-tags">
      {cs.tags.map((t) => <span class="cs-tag">{t}</span>)}
    </div>
    <div class="cs-title">{cs.title}</div>
    <div class="cs-subtitle" set:html={cs.subtitle} />
    <slot name="meta" />
  </div>
  <slot />
  <div class="section" style="border-bottom:none">
    <slot name="footer-prelude" />
    <hr class="cs-rule" />
    <CaseStudyNav slug={slug} />
    <div class="btn-row"><a class="btn" href="/case-studies/">← All case studies</a></div>
  </div>
</Base>
