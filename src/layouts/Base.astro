---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  pageId?: string;
}

const {
  title,
  description = 'Mike Hnath — brand strategist, creative director, and performance marketer based in Connecticut. Founder of THIS, a brand strategy and creative consultancy.',
  pageId
} = Astro.props;

const path = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isActive = (prefix: string) => {
  const target = prefix === '/' ? base + '/' : base + prefix;
  return prefix === '/' ? path === target : path === target || path.startsWith(target);
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" href="/Icons/mikehnath-favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,500;0,700;0,800;1,400&family=Open+Sans:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
  <script is:inline>
    (function () {
      var c;
      try { c = localStorage.getItem('mh-theme'); } catch (e) {}
      if (!['light','dark','auto'].includes(c)) {
        c = window.matchMedia('(max-width: 768px)').matches ? 'dark' : 'auto';
      }
      var mode = c === 'auto'
        ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
        : c;
      document.documentElement.dataset.theme = mode;
    })();
  </script>
</head>
<body>

<!-- ── MOBILE BACKDROP ───────────────────────────────────────── -->
<div class="mobile-backdrop" onclick="closeMobileMenu()"></div>

<!-- ── MOBILE THEME BUBBLE (fixed bottom-right) ──────────────── -->
<button class="mobile-theme-fab" onclick="toggleMobileTheme()" aria-label="Toggle theme">
  <span class="mobile-theme-fab-icon">☀</span>
</button>

<div class="app">

  <!-- ── MOBILE TOP BAR ──────────────────────────────────────── -->
  <div class="mobile-topbar">
    <img src="/Icons/mikehnath-icon.svg" alt="Mike Hnath" class="mobile-topbar-logo" />
    <button class="hamburger" onclick="toggleMobileMenu()" aria-label="Open menu">
      <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="28" y2="6"/><line x1="3" y1="12" x2="28" y2="12"/><line x1="3" y1="18" x2="28" y2="18"/></svg>
    </button>
  </div>

  <!-- ── SIDEBAR ─────────────────────────────────────────────── -->
  <nav class="sidebar">
    <div class="sidebar-logo" onclick="toggleMobileMenu()">
      <span class="sidebar-logo-img" role="img" aria-label="Mike Hnath"></span>
      <button class="mobile-menu-close" onclick="event.stopPropagation();closeMobileMenu()" aria-label="Close menu">✕</button>
    </div>

    <div class="sidebar-nav">
      <a class={`nav-item${isActive('/') ? ' active' : ''}`} data-page="home" href="/">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M11.3 2.3a1 1 0 0 1 1.4 0l9 7.7A1 1 0 0 1 21 12h-1v8a2 2 0 0 1-2 2h-3v-7h-6v7H6a2 2 0 0 1-2-2v-8H3a1 1 0 0 1-.7-1.7z"/></svg></div>
        <span class="nav-label">Home</span>
        <span class="nav-shortcut">1</span>
      </a>
      <a class={`nav-item${isActive('/about/') ? ' active' : ''}`} data-page="about" href="/about/">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm-8 9a8 8 0 0 1 16 0 1 1 0 0 1-1 1H5a1 1 0 0 1-1-1z"/></svg></div>
        <span class="nav-label">About</span>
        <span class="nav-shortcut">2</span>
      </a>
      <a class={`nav-item${isActive('/writing/') ? ' active' : ''}`} data-page="writing" href="/writing/">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3l-1.6 1.6-3-3zM13.8 6.2l3 3L7 19l-4 1 1-4z"/></svg></div>
        <span class="nav-label">Writing</span>
        <span class="nav-shortcut">3</span>
      </a>

      <div class="nav-divider">Career</div>

      <a class={`nav-item${isActive('/experience/') ? ' active' : ''}`} data-page="experience" href="/experience/">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M9 3a2 2 0 0 0-2 2v2H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3V5a2 2 0 0 0-2-2zm6 4V5H9v2z"/></svg></div>
        <span class="nav-label">History</span>
        <span class="nav-shortcut">4</span>
      </a>
      <a class={`nav-item${isActive('/case-studies/') ? ' active' : ''}`} data-page="case-studies" href="/case-studies/">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M3 6a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg></div>
        <span class="nav-label">Case Studies</span>
        <span class="nav-shortcut">5</span>
      </a>
      <a class={`nav-item${isActive('/tools/') ? ' active' : ''}`} data-page="tools" href="/tools/">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 1 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94z"/></svg></div>
        <span class="nav-label">Tools</span>
        <span class="nav-shortcut">6</span>
      </a>

      <div class="nav-divider">Portfolio</div>

      <a class={`nav-item${isActive('/websites/') ? ' active' : ''}`} data-page="websites" href="/websites/">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M4 4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h6v2H7v2h10v-2h-3v-2h6a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4h16V6H4zm2-1.5a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0zM9 6.5a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0z"/></svg></div>
        <span class="nav-label">Websites</span>
        <span class="nav-shortcut">7</span>
      </a>
      <div class="nav-mobile-logo"><span class="sidebar-logo-img" role="img" aria-label="Mike Hnath"></span></div>
      <a class="nav-item nav-ext" href="https://hnath.myportfolio.com" target="_blank" rel="noopener noreferrer">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M9 3a1 1 0 0 0-.8.4L7 5H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-3l-1.2-1.6A1 1 0 0 0 15 3zm3 13.5a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/></svg></div>
        <span class="nav-label">Media</span>
        <span class="nav-shortcut">8</span>
      </a>

      <div class="nav-divider">Connect</div>

      <a class="nav-item nav-ext" href="#contact" onclick="openModal();return false;">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M2 6.6a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2L12 13zM2 8.9V18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8.9l-9.46 6a1 1 0 0 1-1.08 0z"/></svg></div>
        <span class="nav-label">Contact</span>
        <span class="nav-shortcut">9</span>
      </a>
      <a class="nav-item nav-ext" href="https://www.linkedin.com/in/michaelhnath/" target="_blank" rel="noopener noreferrer">
        <div class="nav-icon"><img src="/Icons/linkedin.svg" alt="LinkedIn" /></div>
        <span class="nav-label">LinkedIn</span>
      </a>
    </div>

    <div class="sidebar-footer">
      <div class="theme-bar">
        <div class="theme-toggle">
          <div class="theme-indicator" id="theme-indicator"></div>
          <button class="theme-btn" id="btn-light" onclick="setTheme('light')">Light</button>
          <button class="theme-btn" id="btn-dark" onclick="setTheme('dark')">Dark</button>
          <button class="theme-btn on" id="btn-auto" onclick="setTheme('auto')">Auto</button>
        </div>
      </div>
    </div>
  </nav>

  <!-- ── MAIN CONTENT ─────────────────────────────────────────── -->
  <main class="main">
  <div class="page-frame">
    <div class="page active" id={pageId}>
      <slot />
    </div>
  </div>
  </main>
</div>

<!-- ── CONTACT MODAL ────────────────────────────────────────────── -->
<div class="modal-overlay" id="modal-overlay" onclick="handleOverlay(event)">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <div class="modal-eyebrow">Get in touch</div>
    <div class="modal-title">Let's talk.</div>
    <div class="modal-sub">Available for select consulting, brand strategy, and creative projects. Response within 24 hrs.</div>
    <div class="form-row">
      <div class="form-field"><input class="form-input" type="text" placeholder="Name" aria-label="Name" /></div>
      <div class="form-field"><input class="form-input" type="text" placeholder="Company" aria-label="Company" /></div>
    </div>
    <div class="form-field"><input class="form-input" type="email" placeholder="Email" aria-label="Email" /></div>
    <div class="form-field"><textarea class="form-textarea" placeholder="What's the situation? Brief description — what you're building, what you need, timeline if relevant." aria-label="Message"></textarea></div>
    <button type="button" class="form-submit" onclick="submitContact()">Send message</button>
    <div class="modal-footer">
      <div class="social-pills">
        <a class="social-pill" href="https://www.linkedin.com/in/michaelhnath/" target="_blank" rel="noopener noreferrer"><img src="/Icons/linkedin.svg" style="width:16px;height:16px;display:block" />LinkedIn</a>
        <a class="social-pill" href="https://github.com/MikeHnath" target="_blank" rel="noopener noreferrer"><img src="/Icons/github.svg" style="width:16px;height:16px;display:block" />GitHub</a>
        <a class="social-pill" href="https://hnath.myportfolio.com" target="_blank" rel="noopener noreferrer"><img src="/Icons/adobe-portfolio.svg" style="width:16px;height:16px;display:block" />Portfolio</a>
      </div>
    </div>
  </div>
</div>

<!-- ── IMAGE LIGHTBOX ───────────────────────────────────────────── -->
<div class="lightbox-overlay" id="lightbox-overlay" aria-hidden="true">
  <button class="lightbox-close" type="button" aria-label="Close">✕</button>
  <img class="lightbox-img" id="lightbox-img" alt="" />
</div>

<script is:inline src="/main.js"></script>
</body>
</html>
