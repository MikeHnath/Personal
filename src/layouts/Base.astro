---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Mike Hnath — brand strategist, creative director, and performance marketer based in Connecticut. Founder of THIS, a brand strategy and creative consultancy.'
} = Astro.props;

const path = Astro.url.pathname;
const isActive = (prefix: string) =>
  prefix === '/' ? path === '/' : path === prefix || path.startsWith(prefix);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" href="/Icons/mikehnath-favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,500;0,700;0,800;1,400&family=Open+Sans:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
</head>
<body>

<div class="app">

  <!-- ── MOBILE TOP BAR ──────────────────────────────────────── -->
  <div class="mobile-topbar">
    <img src="/Icons/mikehnath-icon.svg" alt="Mike Hnath" class="mobile-topbar-logo" />
    <button class="hamburger" onclick="toggleMobileMenu()" aria-label="Open menu">
      <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="28" y2="6"/><line x1="3" y1="12" x2="28" y2="12"/><line x1="3" y1="18" x2="28" y2="18"/></svg>
    </button>
  </div>

  <!-- ── SIDEBAR ─────────────────────────────────────────────── -->
  <nav class="sidebar">
    <div class="sidebar-logo">
      <img src="/Icons/mikehnath-icon.svg" alt="Mike Hnath" class="sidebar-logo-img" />
      <button class="mobile-menu-close" onclick="closeMobileMenu()" aria-label="Close menu">✕</button>
    </div>

    <div class="sidebar-nav">
      <a class={`nav-item${isActive('/') ? ' active' : ''}`} data-page="home" href="/">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
        <span class="nav-label">Home</span>
        <span class="nav-shortcut">1</span>
      </a>
      <a class={`nav-item${isActive('/about/') ? ' active' : ''}`} data-page="about" href="/about/">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div>
        <span class="nav-label">About</span>
        <span class="nav-shortcut">2</span>
      </a>
      <a class={`nav-item${isActive('/writing/') ? ' active' : ''}`} data-page="writing" href="/writing/">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></div>
        <span class="nav-label">Writing</span>
        <span class="nav-shortcut">3</span>
      </a>

      <div class="nav-divider">Career</div>

      <a class={`nav-item${isActive('/experience/') ? ' active' : ''}`} data-page="experience" href="/experience/">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg></div>
        <span class="nav-label">Experience</span>
        <span class="nav-shortcut">4</span>
      </a>
      <a class={`nav-item${isActive('/work/') ? ' active' : ''}`} data-page="work" href="/work/">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></div>
        <span class="nav-label">Case Studies</span>
        <span class="nav-shortcut">5</span>
      </a>
      <a class={`nav-item${isActive('/tools/') ? ' active' : ''}`} data-page="tools" href="/tools/">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></div>
        <span class="nav-label">Tools</span>
        <span class="nav-shortcut">6</span>
      </a>

      <div class="nav-divider">Portfolio</div>

      <a class={`nav-item${isActive('/websites/') ? ' active' : ''}`} data-page="websites" href="/websites/">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg></div>
        <span class="nav-label">Websites</span>
        <span class="nav-shortcut">7</span>
      </a>
      <div class="nav-mobile-logo"><img src="/Icons/mikehnath-icon.svg" alt="Mike Hnath" class="sidebar-logo-img" /></div>
      <a class="nav-item nav-ext" href="https://hnath.myportfolio.com" target="_blank" rel="noopener noreferrer">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg></div>
        <span class="nav-label">Media</span>
        <span class="nav-shortcut">8</span>
      </a>

      <div class="nav-divider">Connect</div>

      <a class="nav-item nav-ext" href="#contact" onclick="openModal();return false;">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
        <span class="nav-label">Contact</span>
        <span class="nav-shortcut">9</span>
      </a>
      <a class="nav-item nav-ext" href="https://www.linkedin.com/in/michaelhnath/" target="_blank" rel="noopener noreferrer">
        <div class="nav-icon"><img src="/Icons/linkedin.svg" alt="LinkedIn" /></div>
        <span class="nav-label">LinkedIn</span>
      </a>
    </div>

    <div class="sidebar-footer">
      <div class="theme-bar">
        <div class="theme-toggle">
          <div class="theme-indicator" id="theme-indicator"></div>
          <button class="theme-btn" id="btn-light" onclick="setTheme('light')">Light</button>
          <button class="theme-btn" id="btn-dark" onclick="setTheme('dark')">Dark</button>
          <button class="theme-btn on" id="btn-auto" onclick="setTheme('auto')">Auto</button>
        </div>
      </div>
    </div>
  </nav>

  <!-- ── MAIN CONTENT ─────────────────────────────────────────── -->
  <main class="main">
  <div class="page-frame">
    <div class="page active">
      <slot />
    </div>
  </div>
  </main>
</div>

<!-- ── CONTACT MODAL ────────────────────────────────────────────── -->
<div class="modal-overlay" id="modal-overlay" onclick="handleOverlay(event)">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <div class="modal-eyebrow">Get in touch</div>
    <div class="modal-title">Let's talk.</div>
    <div class="modal-sub">Available for select consulting, brand strategy, and creative projects. Response within 24 hrs.</div>
    <div class="intent-label">What are you looking for?</div>
    <div class="intent-chips">
      <button class="intent-chip selected" onclick="toggleChip(this)">Brand strategy</button>
      <button class="intent-chip" onclick="toggleChip(this)">Creative direction</button>
      <button class="intent-chip" onclick="toggleChip(this)">Paid media</button>
      <button class="intent-chip" onclick="toggleChip(this)">GTM / launch</button>
      <button class="intent-chip" onclick="toggleChip(this)">Something else</button>
    </div>
    <div class="form-row">
      <div class="form-field"><label class="form-label">Name</label><input class="form-input" type="text" placeholder="Your name" /></div>
      <div class="form-field"><label class="form-label">Company</label><input class="form-input" type="text" placeholder="Optional" /></div>
    </div>
    <div class="form-field"><label class="form-label">Email</label><input class="form-input" type="email" placeholder="you@company.com" /></div>
    <div class="form-field"><label class="form-label">What's the situation?</label><textarea class="form-textarea" placeholder="Brief description — what you're building, what you need, timeline if relevant."></textarea></div>
    <button class="form-submit">Send message</button>
    <div class="modal-footer">
      <div class="social-pills">
        <a class="social-pill" href="https://www.linkedin.com/in/michaelhnath/" target="_blank"><img src="/Icons/linkedin.svg" style="width:16px;height:16px;display:block" />LinkedIn</a>
        <a class="social-pill" href="https://github.com/MikeHnath" target="_blank"><img src="/Icons/github.svg" style="width:16px;height:16px;display:block" />GitHub</a>
        <a class="social-pill" href="https://hnath.myportfolio.com" target="_blank"><img src="/Icons/adobe-portfolio.svg" style="width:16px;height:16px;display:block" />Portfolio</a>
      </div>
    </div>
  </div>
</div>

<script is:inline src="/main.js"></script>
</body>
</html>
