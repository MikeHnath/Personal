---
import Base from '../layouts/Base.astro';
---
<Base title="Writing — Mike Hnath">

  <div class="section" style="min-height:calc(100vh - 200px);display:flex;flex-direction:column;justify-content:center;align-items:flex-start">
    <div class="section-label" style="margin-bottom:12px">Writing</div>
    <div class="page-title" style="margin-bottom:14px">Coming soon</div>
    <div class="body-text" style="max-width:560px;margin-bottom:24px">A long-form notebook on brand strategy, marketing ops, GTM, and lessons from the road — currently in draft. Check back shortly, or follow along on <a href="https://www.linkedin.com/in/michaelhnath/" target="_blank" rel="noopener noreferrer" style="text-decoration:underline">LinkedIn</a> for early pieces.</div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <a class="btn primary" href="/">Back to home</a>
      <button class="btn secondary" onclick="openModal()">Get in touch</button>
    </div>
  </div>

</Base>
