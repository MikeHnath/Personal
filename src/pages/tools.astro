---
import Base from '../layouts/Base.astro';
---
<Base title="Tools — Mike Hnath">

  <div class="section">
    <div class="page-title">Tools</div>
    <div class="page-subtitle">A curated list of software, services, and resources I use regularly across brand, performance, and creative work.</div>
    <div class="filter-bar">
      <button class="filter-pill active" onclick="filterTools(this,'all')">All</button>
      <button class="filter-pill" onclick="filterTools(this,'creative')">Creative</button>
      <button class="filter-pill" onclick="filterTools(this,'marketing')">Marketing</button>
      <button class="filter-pill" onclick="filterTools(this,'web')">Web</button>
      <button class="filter-pill" onclick="filterTools(this,'ai')">AI</button>
    </div>
    <div class="tools-grid" id="tools-grid">

      <a class="tool-card" data-cat="creative" href="https://www.adobe.com/products/photoshop.html" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/adobe-photoshop.svg" alt="Adobe Photoshop" /></div>
        <div class="tool-info"><div class="tool-name">Photoshop</div><div class="tool-desc">Photo editing, compositing, digital painting. Daily driver for asset production.</div></div>
      </a>
      <a class="tool-card" data-cat="creative" href="https://www.adobe.com/products/illustrator.html" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/adobe-illustrator.svg" alt="Adobe Illustrator" /></div>
        <div class="tool-info"><div class="tool-name">Illustrator</div><div class="tool-desc">Vector illustration, logo systems, packaging dielines, and brand identity work.</div></div>
      </a>
      <a class="tool-card" data-cat="creative" href="https://www.adobe.com/products/indesign.html" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/adobe-indesign.svg" alt="Adobe InDesign" /></div>
        <div class="tool-info"><div class="tool-name">InDesign</div><div class="tool-desc">Multi-page layout for pitch decks, investor materials, and print collateral.</div></div>
      </a>
      <a class="tool-card" data-cat="creative" href="https://www.adobe.com/products/premiere.html" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/adobe-premiere-pro.svg" alt="Adobe Premiere Pro" /></div>
        <div class="tool-info"><div class="tool-name">Premiere Pro</div><div class="tool-desc">Video editing for brand content, product videos, and social cuts.</div></div>
      </a>
      <a class="tool-card" data-cat="creative" href="https://www.adobe.com/products/aftereffects.html" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/adobe-after-effects.svg" alt="Adobe After Effects" /></div>
        <div class="tool-info"><div class="tool-name">After Effects</div><div class="tool-desc">Motion graphics, animated brand assets, and video post-production.</div></div>
      </a>
      <a class="tool-card" data-cat="creative" href="https://www.figma.com" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/figma.svg" alt="Figma" /></div>
        <div class="tool-info"><div class="tool-name">Figma</div><div class="tool-desc">UI/UX design, prototyping, and collaborative design systems.</div></div>
      </a>
      <a class="tool-card" data-cat="creative" href="https://www.canva.com" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/canva.svg" alt="Canva" /></div>
        <div class="tool-info"><div class="tool-name">Canva</div><div class="tool-desc">Rapid content creation and social graphics for client and brand work.</div></div>
      </a>
      <a class="tool-card" data-cat="creative" href="https://www.apple.com/logic-pro/" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/logic-pro.png" alt="Logic Pro" /></div>
        <div class="tool-info"><div class="tool-name">Logic Pro</div><div class="tool-desc">Audio production and mixing. Carried over from music career, still active.</div></div>
      </a>

      <a class="tool-card" data-cat="marketing" href="https://www.facebook.com/business/ads" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/meta.svg" alt="Meta Ads" /></div>
        <div class="tool-info"><div class="tool-name">Meta Ads</div><div class="tool-desc">Paid social campaign management across Facebook and Instagram.</div></div>
      </a>
      <a class="tool-card" data-cat="marketing" href="https://business.linkedin.com/marketing-solutions/ads" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/linkedin.svg" alt="LinkedIn Ads" /></div>
        <div class="tool-info"><div class="tool-name">LinkedIn Ads</div><div class="tool-desc">B2B paid social. Audience targeting, lead gen, and ABM campaigns.</div></div>
      </a>
      <a class="tool-card" data-cat="marketing">
        <div class="tool-icon"><img src="/Personal/Icons/lasso.svg" alt="Lasso DSP" /></div>
        <div class="tool-info"><div class="tool-name">Lasso DSP</div><div class="tool-desc">Programmatic media buying platform. Power user across 25 concurrent campaigns.</div></div>
      </a>
      <a class="tool-card" data-cat="marketing" href="https://analytics.google.com" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/ga4.svg" alt="Google Analytics" /></div>
        <div class="tool-info"><div class="tool-name">Google Analytics</div><div class="tool-desc">Web analytics, conversion tracking, and campaign performance measurement.</div></div>
      </a>
      <a class="tool-card" data-cat="marketing" href="https://www.hubspot.com" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/hubspot.svg" alt="HubSpot" /></div>
        <div class="tool-info"><div class="tool-name">HubSpot</div><div class="tool-desc">CRM, email marketing, and marketing automation. Currently building out.</div></div>
      </a>
      <a class="tool-card" data-cat="marketing" href="https://www.salesforce.com" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/salesforce.svg" alt="Salesforce" /></div>
        <div class="tool-info"><div class="tool-name">Salesforce</div><div class="tool-desc">CRM and pipeline management. Used heavily at Triax for enterprise sales.</div></div>
      </a>
      <a class="tool-card" data-cat="marketing" href="https://www.marketo.com" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/marketo.svg" alt="Marketo" /></div>
        <div class="tool-info"><div class="tool-name">Marketo</div><div class="tool-desc">Marketing automation and email workflows for demand gen and nurture programs.</div></div>
      </a>
      <a class="tool-card" data-cat="marketing" href="https://mailchimp.com" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/mail-chimp.svg" alt="Mailchimp" /></div>
        <div class="tool-info"><div class="tool-name">Mailchimp</div><div class="tool-desc">Email marketing and campaign management for SMB clients.</div></div>
      </a>

      <a class="tool-card" data-cat="web" href="https://github.com" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/github.svg" alt="GitHub" /></div>
        <div class="tool-info"><div class="tool-name">GitHub</div><div class="tool-desc">Version control and project hosting. All personal and client web builds live here.</div></div>
      </a>
      <a class="tool-card" data-cat="web" href="https://wordpress.org" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/wordpress.svg" alt="WordPress" /></div>
        <div class="tool-info"><div class="tool-name">WordPress</div><div class="tool-desc">CMS for client sites. Scandalous, Pine Island Games, Greenwich Film Festival.</div></div>
      </a>
      <a class="tool-card" data-cat="web" href="https://developer.mozilla.org/en-US/docs/Web/HTML" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/html5.svg" alt="HTML5" /></div>
        <div class="tool-info"><div class="tool-name">HTML5</div><div class="tool-desc">Semantic markup, landing pages, email templates, and custom builds.</div></div>
      </a>
      <a class="tool-card" data-cat="web" href="https://developer.mozilla.org/en-US/docs/Web/CSS" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/css3.svg" alt="CSS3" /></div>
        <div class="tool-info"><div class="tool-name">CSS3</div><div class="tool-desc">Layout, responsive design, animation, and design system implementation.</div></div>
      </a>
      <a class="tool-card" data-cat="web" href="https://www.wix.com" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/wix.svg" alt="Wix" /></div>
        <div class="tool-info"><div class="tool-name">Wix</div><div class="tool-desc">Quick-deploy sites for SMB clients and project-based work.</div></div>
      </a>
      <a class="tool-card" data-cat="ai" href="https://claude.ai" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/claude.svg" alt="Claude" /></div>
        <div class="tool-info"><div class="tool-name">Claude</div><div class="tool-desc">Strategy, writing, research, and workflow automation. Primary AI partner.</div></div>
      </a>
      <a class="tool-card" data-cat="ai" href="https://chat.openai.com" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/chatgpt.svg" alt="ChatGPT" /></div>
        <div class="tool-info"><div class="tool-name">ChatGPT</div><div class="tool-desc">Content drafting, brainstorming, and creative production workflows.</div></div>
      </a>
      <a class="tool-card" data-cat="ai" href="https://suno.com" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/suno-ai.svg" alt="Suno" /></div>
        <div class="tool-info"><div class="tool-name">Suno</div><div class="tool-desc">AI audio generation for brand content and creative exploration.</div></div>
      </a>
      <a class="tool-card" data-cat="ai,productivity" href="https://notion.so" target="_blank" rel="noopener noreferrer">
        <div class="tool-icon"><img src="/Personal/Icons/notion.svg" alt="Notion" /></div>
        <div class="tool-info"><div class="tool-name">Notion</div><div class="tool-desc">Project management, documentation, and knowledge base. Building out.</div></div>
      </a>

    </div>
  </div>

</Base>
