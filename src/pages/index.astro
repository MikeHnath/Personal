---
import Base from '../layouts/Base.astro';
import FeaturedWorkCard from '../components/FeaturedWorkCard.astro';
import WaveformCanvas from '../components/WaveformCanvas.astro';
import { caseStudies } from '../data/caseStudies';

const homeWork = caseStudies.slice(0, 4);
---
<Base title="Mike Hnath — Portfolio" pageId="page-home">

  <div class="section" style="padding-bottom:0;position:relative;z-index:1">
    <div class="home-intro-grid" style="display:grid;grid-template-columns:minmax(0,3fr) minmax(0,1fr);gap:28px;align-items:start">
      <div>
        <div id="home-greeting" style="font-size:96px;font-weight:300;color:var(--text);line-height:1;margin-top:24px;margin-bottom:16px;letter-spacing:-2px;font-family:var(--font-display)">Hello!</div>
        <div class="body-text" style="margin-bottom:16px">I'm <strong>Mike Hnath</strong> (pronounced Nath), former touring drummer who runs my own consultancy. I help brands find their footing, tell their story, and grow with purpose.</div>
        <div style="display:flex;gap:8px;margin-bottom:16px">
          <a class="btn primary" href="/case-studies/">View case studies</a>
          <button class="btn secondary" onclick="openModal()">Get in touch</button>
        </div>
      </div>
      <div id="shortcut-tip" style="background:var(--bg2);border:none;border-radius:var(--r-lg);padding:18px 16px;position:relative;margin-top:10px">
        <button onclick="document.getElementById('shortcut-tip').style.display='none'" style="position:absolute;top:8px;right:10px;background:none;border:none;cursor:pointer;font-size:14px;color:var(--text3);line-height:1">✕</button>
        <div style="font-size:12px;font-weight:800;color:var(--text);margin-bottom:6px">Navigate quickly</div>
        <div style="font-size:12px;color:var(--text2);line-height:1.6">Use keyboard shortcuts <strong style="color:var(--text)">1 → 9</strong> to jump between pages. Try pressing <strong style="color:var(--text)">2</strong>, <strong style="color:var(--text)">3</strong> or <strong style="color:var(--text)">4</strong>.</div>
      </div>
    </div>
  </div>

  <div class="section home-wave" style="padding:0;position:relative;z-index:0;height:800px;margin-top:-286px;margin-bottom:-524px;overflow:visible;pointer-events:none;transform:rotate(-7deg);transform-origin:center">
    <WaveformCanvas lines={240} amplitude={276} speed={0.096} />
  </div>

  <div class="section home-featured" style="padding-top:40px;padding-bottom:61px;position:relative;z-index:1;background:transparent">
    <div class="section-header">
      <div class="section-label" style="margin-bottom:0">Featured work</div>
      <a class="show-more" href="/case-studies/" style="margin-top:0">View all</a>
    </div>
    <div id="home-work" class="home-work-grid">
      {homeWork.map((study) => <FeaturedWorkCard study={study} />)}
    </div>
    <div class="portfolio-grid" style="margin-top:32px">
      <a class="nav-tile" href="/case-studies/">
        <div class="nav-tile-title">Case Studies</div>
        <div class="nav-tile-desc">Brand, GTM, performance media, and eComm. Full write-ups with context and results.</div>
        <div class="nav-tile-cta">View case studies →</div>
      </a>
      <a class="nav-tile" href="/websites/">
        <div class="nav-tile-title">Websites</div>
        <div class="nav-tile-desc">Live builds + GitHub projects. WordPress, Webflow, custom HTML.</div>
        <div class="nav-tile-cta">View websites →</div>
      </a>
      <a class="nav-tile" href="https://hnath.myportfolio.com" target="_blank" rel="noopener noreferrer">
        <div class="nav-tile-title">Media</div>
        <div class="nav-tile-desc">Photography and videography. Brand shoots, product content, live event coverage.</div>
        <div class="nav-tile-cta">View media →</div>
      </a>
    </div>
  </div>

  <div class="section" style="padding:24px 34px 0;overflow:hidden">
    <div style="font-weight:400;color:var(--text2);font-family:var(--font-display);font-size:var(--fs-h3);text-align:center;text-transform:uppercase;letter-spacing:.16em">Trusted by 100+ brands and small businesses globally</div>
  </div>

  <div class="section" style="padding:0;overflow:hidden">
    <div class="ticker-wrap ticker--inverse">
      <div class="ticker-fade-l"></div>
      <div class="ticker-fade-r"></div>
      <div class="ticker-row">
        <div class="ticker-track" id="ticker1"></div>
        <div class="ticker-track" id="ticker2" aria-hidden="true"></div>
      </div>
      <div class="ticker-row ticker-row--reverse">
        <div class="ticker-track" id="ticker3"></div>
        <div class="ticker-track" id="ticker4" aria-hidden="true"></div>
      </div>
    </div>
  </div>

  <div class="section" style="padding-bottom:25px">
    <div class="section-header">
      <div class="section-label" style="margin-bottom:0">Personal updates</div>
      <a class="show-more" href="/about/" style="margin-top:0">View all</a>
    </div>
    <div class="update-grid" id="home-updates"></div>
  </div>

  <div class="section">
    <div class="section-header" style="margin-bottom:16px">
      <div class="section-label" style="margin-bottom:0">Read my latest thoughts</div>
    </div>
    <div style="padding:32px 16px;background:var(--bg2);border-radius:var(--r-lg);text-align:center">
      <div style="font-size:var(--fs-h3);font-weight:700;color:var(--text);font-family:var(--font-display);margin-bottom:6px">Blog coming soon</div>
      <div style="font-size:var(--fs-body-sm);color:var(--text2);line-height:1.5">Writing is in progress — check back shortly.</div>
    </div>
  </div>

  <div class="section" style="border-bottom:none">
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px">
      <img src="/Logos/mikehnath-logo.svg" style="height:12px;width:auto;display:block;filter:var(--logo-filter,none)" />
      <div class="social-pills">
        <a class="social-pill" href="https://www.linkedin.com/in/michaelhnath/" target="_blank" rel="noopener noreferrer"><img src="/Icons/linkedin.svg" style="width:16px;height:16px;display:block" />LinkedIn</a>
        <a class="social-pill" href="https://github.com/MikeHnath" target="_blank" rel="noopener noreferrer"><img src="/Icons/github.svg" style="width:16px;height:16px;display:block" />GitHub</a>
        <a class="social-pill" href="https://hnath.myportfolio.com" target="_blank" rel="noopener noreferrer"><img src="/Icons/adobe-portfolio.svg" style="width:16px;height:16px;display:block" />Portfolio</a>
      </div>
      <div style="font-size:11px;color:var(--text3)">Connecticut, USA · Available for select work</div>
    </div>
  </div>

</Base>
