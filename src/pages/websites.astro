---
import Base from '../layouts/Base.astro';
---
<Base title="Websites — Mike Hnath">

  <div class="section">
    <div class="page-title">Websites</div>
    <div class="page-subtitle">Live builds, client projects, and GitHub experiments.</div>
    <div class="project-grid">
      <div class="project-card">
        <div class="project-thumb" style="background:#957645;padding:0;position:relative">
          <iframe src="/Images/mikehnath-github-MarkAnthony-screenshot-phone-mockup.html" style="position:absolute;inset:0;width:100%;height:100%;border:none;pointer-events:auto" scrolling="no"></iframe>
        </div>
        <a href="https://github.com/MikeHnath/MarkAnthony" target="_blank" rel="noopener noreferrer" style="display:block;text-decoration:none">
          <div class="project-body">
            <div class="project-title">Mark Anthony Home Improvement — Concept mobile-first website with lead gen</div>
            <div class="project-tags"><span class="project-tag">HTML</span><span class="project-tag">CSS</span><span class="project-tag">Concept</span><span class="project-tag">GitHub</span></div>
            <div class="project-desc">Spec build for a CT general contractor. Custom-coded responsive site with brand identity, gallery, and inline quote capture.</div>
          </div>
        </a>
      </div>
      <div class="project-card">
        <a href="https://github.com/MikeHnath/stonewater" target="_blank" rel="noopener noreferrer" style="display:block;text-decoration:none">
          <div class="project-thumb">
            <img src="/Images/github-concept-stonewater-preview.webp" alt="Stonewater concept site preview" style="width:100%;height:100%;object-fit:cover;display:block" />
          </div>
        </a>
        <div class="project-body">
          <div class="project-title">Stonewater — Concept website for a fictitious brand</div>
          <div class="project-tags"><span class="project-tag">HTML</span><span class="project-tag">CSS</span><span class="project-tag">Concept</span><span class="project-tag">GitHub</span></div>
          <div class="project-desc">Spec build exploring what a premium Fairfield County outdoor living brand could look like online. Custom-coded, zero templates.</div>
        </div>
      </div>
      <div class="project-card">
        <a href="https://wbccmilford.org/" target="_blank" rel="noopener noreferrer" style="display:block;text-decoration:none">
          <div class="project-thumb" style="background:#6385d8;padding:12px 0">
            <img src="/Images/WBCC-website.webp" alt="Wildermere Beach Church website" style="width:80%;height:90%;object-fit:cover;display:block" />
          </div>
        </a>
        <div class="project-body">
          <div class="project-title">Wildermere Beach Church — Brand and church website</div>
          <div class="project-tags"><span class="project-tag">Ministry Designs</span><span class="project-tag">Photography</span><span class="project-tag">Branding</span><span class="project-tag">Client</span></div>
          <div class="project-desc">Full brand identity and website for a Connecticut shoreline congregation. Clean, welcoming design built to serve both new visitors and the existing community.</div>
        </div>
      </div>
      <div class="project-card">
        <a href="https://www.scandalouschocolates.com/" target="_blank" rel="noopener noreferrer" style="display:block;text-decoration:none">
          <div class="project-thumb" style="background:#e19925;padding:12px 0">
            <video autoplay muted loop playsinline style="width:80%;height:90%;object-fit:cover;display:block">
              <source src="/Video/scandalous-web-homepage.mp4" type="video/mp4" />
            </video>
          </div>
        </a>
        <div class="project-body">
          <div class="project-title">Scandalous Chocolates — Brand and CPG website</div>
          <div class="project-tags"><span class="project-tag">Wix</span><span class="project-tag">Cannabis</span><span class="project-tag">Client</span></div>
          <div class="project-desc">Brand identity and e-commerce-ready website for a premium chocolate brand. Packaging-forward design built to convert on shelf and online.</div>
        </div>
      </div>
    </div>
    <div style="margin-top:24px;text-align:left"><a class="btn" href="/tools/#web" style="display:inline-flex;align-items:center;gap:10px"><svg viewBox="0 0 24 24" style="width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>View my tech stack<span style="background:rgba(255,255,255,0.18);font-family:var(--font-mono);font-size:9px;padding:2px 6px;border-radius:4px;font-weight:500;line-height:1.4">6</span></a></div>
  </div>

</Base>
