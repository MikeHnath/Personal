---
import Base from '../layouts/Base.astro';
---
<Base title="Case Studies — Mike Hnath">

  <div class="section">
    <div class="page-header">
      <div class="page-title">Case Studies</div>
      <div class="page-count">6 projects</div>
    </div>
    <div class="page-subtitle">Selected case studies across brand strategy, performance media, GTM, and creative direction.</div>
    <div class="filter-bar">
      <button class="filter-pill active" onclick="filterWork(this,'all')">All</button>
      <button class="filter-pill" onclick="filterWork(this,'brand')">Brand</button>
      <button class="filter-pill" onclick="filterWork(this,'performance')">Performance</button>
      <button class="filter-pill" onclick="filterWork(this,'gtm')">GTM</button>
      <button class="filter-pill" onclick="filterWork(this,'design')">Design</button>
      <button class="filter-pill" onclick="filterWork(this,'web')">Web</button>
    </div>
    <div class="section-label" style="margin-bottom:10px">By the numbers</div>
    <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;margin-bottom:24px">
      <div class="stat-box" style="aspect-ratio:5/4"><div class="stat-num">$1M+</div><div class="stat-label">Paid media managed</div></div>
      <div class="stat-box" style="aspect-ratio:5/4"><div class="stat-num">15+ yrs</div><div class="stat-label">Brand &amp; marketing</div></div>
      <div class="stat-box" style="aspect-ratio:5/4"><div class="stat-num">$500K+</div><div class="stat-label">Client funding raised</div></div>
    </div>
    <div class="section-row-label">Featured</div>
    <div class="work-grid" style="margin-bottom:24px">
      <a class="work-card" data-tags="brand,gtm" href="/Personal/case-studies/scandalous/">
        <div class="work-thumb">[Scandalous brand visual]</div>
        <div class="work-body"><div class="work-client">THIS · 9-year client</div><div class="work-title">Scandalous — Brand system, packaging, and multi-state GTM</div><div class="work-outcome">$500K+ raised · 11–13 SKUs · 5 states · anchor retainer</div><div class="work-meta"><span class="work-industry">Cannabis · Regulated consumer</span><span class="work-arrow">→</span></div></div>
      </a>
      <a class="work-card" data-tags="performance" href="/Personal/case-studies/pocn/">
        <div class="work-thumb" style="padding:0"><img src="/Personal/Images/POCN/pocn-cs-gfx-2.jpg" alt="" /></div>
        <div class="work-body"><div class="work-client">POCN · 2022–2024</div><div class="work-title">Pharma media management — DSP migration and campaign ops at scale</div><div class="work-outcome">$1.7M+ managed · 30 concurrent campaigns · 50+ pharma therapies</div><div class="work-meta"><span class="work-industry">Healthcare · Pharma</span><span class="work-arrow">→</span></div></div>
      </a>
    </div>
    <div class="section-row-label">All projects</div>
    <div class="work-grid">
      <a class="work-card" data-tags="gtm,brand" href="/Personal/case-studies/sigil/">
        <div class="work-thumb">[SIGIL Kickstarter]</div>
        <div class="work-body"><div class="work-client">Pine Island Games · 2023</div><div class="work-title">SIGIL — Zero-to-launch GTM for original IP</div><div class="work-outcome">$22K+ crowdfunded · full positioning + packaging + campaign</div><div class="work-meta"><span class="work-industry">Consumer · Gaming</span><span class="work-arrow">→</span></div></div>
      </a>
      <a class="work-card" data-tags="design" href="/Personal/case-studies/kraft-heinz/">
        <div class="work-thumb">[KH MiO digital shelf]</div>
        <div class="work-body"><div class="work-client">Kraft Heinz via Imaginary · 2020–2021</div><div class="work-title">Kraft Heinz — Digital shelf and eComm creative</div><div class="work-outcome">~8% Amazon lift · 800+ assets · 30 brands · 15 A+ pages</div><div class="work-meta"><span class="work-industry">CPG · eCommerce</span><span class="work-arrow">→</span></div></div>
      </a>
      <a class="work-card" data-tags="brand,design" href="/Personal/case-studies/infinity/">
        <div class="work-thumb">[Infinity licensed brands]</div>
        <div class="work-body"><div class="work-client">Infinity Lifestyle Brands · 2018–2019</div><div class="work-title">Infinity — Licensed CPG brand direction and packaging at scale</div><div class="work-outcome">$10M+ licensing ecosystem · 50+ SKUs · Disney, MLBPA, Viacom</div><div class="work-meta"><span class="work-industry">CPG · Licensed consumer</span><span class="work-arrow">→</span></div></div>
      </a>
      <a class="work-card" data-tags="brand,gtm" href="/Personal/case-studies/ark/">
        <div class="work-thumb">[Ark of the Covenant]</div>
        <div class="work-body"><div class="work-client">Ark of the Covenant · 2008–2016</div><div class="work-title">Ark of the Covenant — Independent artist brand built from zero</div><div class="work-outcome">350+ shows · 20K+ followers · 2 distribution deals · Mesa/Boogie endorsement</div><div class="work-meta"><span class="work-industry">Music · Independent</span><span class="work-arrow">→</span></div></div>
      </a>
    </div>
    <div style="margin-top:24px"><a class="show-more show-more-em" href="/Personal/tools/">See the tools I use to make these happen ⇢</a></div>
  </div>

</Base>
